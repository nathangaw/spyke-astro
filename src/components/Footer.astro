---
const year = new Date().getFullYear();

const companyLinks = [
  { label: "About", href: "#about" },
  { label: "Work", href: "#work" },
  { label: "Services", href: "#services" },
  { label: "Careers", href: "#" },
];

const resourceLinks = [
  { label: "Blog", href: "#" },
  { label: "Case Studies", href: "/work" },
  { label: "Newsletter", href: "#" },
];

const socialLinks = [
  {
    label: "Twitter",
    href: "#",
    path: `<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>`,
  },
  {
    label: "LinkedIn",
    href: "#",
    path: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>`,
  },
  {
    label: "GitHub",
    href: "#",
    path: `<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>`,
  },
];
---

<footer class="bg-secondary/50 border-t border-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="relative w-10 h-10">
            <div
              class="absolute inset-1 rounded-md bg-primary flex items-center justify-center"
            >
              <span class="text-primary-foreground font-bold text-lg">S</span>
            </div>
          </div>
          <span class="text-xl font-semibold text-foreground">Spyke</span>
        </a>
        <p class="text-muted-foreground text-sm leading-relaxed max-w-xs mb-6">
          Building cutting-edge web experiences for the education sector,
          powered by artificial intelligence.
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                class="w-10 h-10 rounded-lg bg-card border border-border flex items-center justify-center hover:border-primary hover:text-primary transition-colors"
                aria-label={social.label}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={social.path}
                />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Company links -->
      <div>
        <h4 class="text-sm font-semibold text-foreground mb-4">Company</h4>
        <ul class="space-y-3">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Resources links -->
      <div>
        <h4 class="text-sm font-semibold text-foreground mb-4">Resources</h4>
        <ul class="space-y-3">
          {
            resourceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="text-sm font-semibold text-foreground mb-4">
          Stay Updated
        </h4>
        <p class="text-sm text-muted-foreground mb-4">
          Subscribe to our newsletter for EdTech insights.
        </p>
        <form class="flex gap-2">
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 px-3 py-2 rounded-lg bg-background border border-border text-sm focus:border-primary focus:outline-none"
          />
          <button
            type="submit"
            class="px-4 py-2 rounded-lg bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-16 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4"
    >
      <p class="text-sm text-muted-foreground">
        &copy; {year} Spyke Digital. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a
          href="#"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          Privacy Policy
        </a>
        <a
          href="#"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
