---
const testimonials = [
  {
    quote:
      "Spyke have transformed our digital learning platform with their innovative AI solutions. The new features they have implemented have significantly enhanced the learning experience for both students and teachers.",
    author: "Dr. Sarah Mitchell",
    role: "Director of Digital Learning",
    organization: "Garnet Education",
  },
  {
    quote:
      "Spyke have become part of our team, providing advice and guidance on everything web related. I would certainly recommend them to any business looking for a quality, honest and flexible professional service.",
    author: "James Chen",
    role: "CEO",
    organization: "Core Learning",
  },
];
---

<section class="py-24 md:py-32 bg-background">
  <div class="max-w-4xl mx-auto px-6 lg:px-8">
    <!-- Quote icon -->
    <div data-reveal class="flex justify-center mb-12">
      <div
        class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary"
        >
          <path
            d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 2v10c0 2.48 1.53 4 4 6"
          ></path>
          <path
            d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 2v10c0 2.48 1.53 4 4 6"
          ></path>
        </svg>
      </div>
    </div>

    <!-- Testimonial slides -->
    <div class="relative min-h-70 md:min-h-55">
      {
        testimonials.map((t, index) => (
          <div
            data-testimonial={index}
            class={`absolute inset-0 transition-all duration-500 ${
              index === 0
                ? "opacity-100 translate-y-0"
                : "opacity-0 translate-y-4 pointer-events-none"
            }`}
          >
            <blockquote class="text-center">
              <p class="text-xl md:text-2xl lg:text-3xl text-foreground leading-relaxed mb-8 text-balance">
                &ldquo;{t.quote}&rdquo;
              </p>
              <footer>
                <cite class="not-italic">
                  <!--<span class="block text-foreground font-semibold">
                    {t.author}
                  </span>-->
                  <span class="block text-sm text-muted-foreground mt-1">
                    {t.organization}
                  </span>
                </cite>
              </footer>
            </blockquote>
          </div>
        ))
      }
    </div>

    <!-- Navigation dots -->
    <div
      data-reveal
      style="transition-delay: 300ms"
      class="flex justify-center gap-3 mt-12"
    >
      {
        testimonials.map((_, index) => (
          <button
            type="button"
            data-dot={index}
            class={`h-2 rounded-full transition-all duration-300 ${
              index === 0
                ? "w-8 bg-primary"
                : "w-2 bg-border hover:bg-muted-foreground"
            }`}
            aria-label={`View testimonial ${index + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>("[data-testimonial]");
  const dots = document.querySelectorAll<HTMLElement>("[data-dot]");
  let active = 0;
  let interval: number;

  function goTo(index: number) {
    slides[active].classList.add("opacity-0", "translate-y-4", "pointer-events-none");
    slides[active].classList.remove("opacity-100", "translate-y-0");
    dots[active].classList.remove("w-8", "bg-primary");
    dots[active].classList.add("w-2", "bg-border");

    active = index;

    slides[active].classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
    slides[active].classList.add("opacity-100", "translate-y-0");
    dots[active].classList.add("w-8", "bg-primary");
    dots[active].classList.remove("w-2", "bg-border");
  }

  function startAutoPlay() {
    interval = window.setInterval(() => {
      goTo((active + 1) % slides.length);
    }, 6000);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      clearInterval(interval);
      goTo(i);
      startAutoPlay();
    });
  });

  startAutoPlay();
</script>
