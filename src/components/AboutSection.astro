---
const values = [
  {
    number: "01",
    title: "Education First",
    description:
      "Technology should amplify teaching, not complicate it. Every decision starts with the learner.",
  },
  {
    number: "02",
    title: "Innovation Driven",
    description:
      "We stay at the cutting edge of AI and web technology to deliver transformative solutions.",
  },
  {
    number: "03",
    title: "Partnership Focused",
    description:
      "We build long-term relationships with our clients, working closely to understand their needs and deliver solutions that drive success.",
  },
];
---

<section id="about" class="py-24 md:py-32 bg-secondary/30">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Left column -->
      <div>
        <p
          data-reveal
          class="text-sm text-primary font-medium uppercase tracking-wider mb-4"
        >
          About Spyke
        </p>
        <h2
          data-reveal
          style="transition-delay: 100ms"
          class="text-3xl md:text-4xl font-bold text-foreground mb-6"
        >
          Pioneering the future of<br />
          <span class="text-primary">education technology</span>
        </h2>
        <div
          data-reveal
          style="transition-delay: 200ms"
          class="space-y-4 text-muted-foreground leading-relaxed"
        >
          <p>
            Spyke was founded with a singular vision: to transform how
            educational organisations engage with technology. We believe that AI
            and modern web development can make learning more accessible,
            engaging, and effective.
          </p>
          <p>
            Our team combines deep technical expertise with genuine passion for
            education. Many of us have backgrounds in teaching and educational publishing, giving us unique insight into the challenges educators and publishers face.
          </p>
          <p>
            Today, we partner with organisations around the world, helping them build digital
            experiences that truly serve their communities.
          </p>
        </div>
      </div>

      <!-- Right column -->
      <div data-reveal style="transition-delay: 300ms">
        <div class="relative">
          <!-- Animated graphic -->
          <div class="relative w-full aspect-square max-w-md mx-auto mb-12">
            <div class="absolute inset-0 rounded-full border border-border">
            </div>
            <div
              class="absolute inset-4 rounded-full border border-primary/30"
            ></div>
            <div
              class="absolute inset-8 rounded-full border border-primary/50"
            ></div>
            <div
              class="absolute inset-12 rounded-full bg-primary/10 flex items-center justify-center"
            >
              <div class="text-center">
                <div class="text-5xl font-bold text-primary">S</div>
                <div
                  class="text-xs text-muted-foreground mt-2 uppercase tracking-widest"
                >
                  Spyke
                </div>
              </div>
            </div>
            <!-- Orbiting dots -->
            <div class="absolute inset-0 animate-slow-spin">
              <div
                class="absolute top-0 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-primary"
              ></div>
            </div>
            <div class="absolute inset-4 animate-slow-spin-reverse">
              <div
                class="absolute bottom-0 left-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-primary/50"
              ></div>
            </div>
          </div>

          <!-- Values carousel -->
          <div class="relative h-32">
            {
              values.map((value, index) => (
                <div
                  data-value={index}
                  class={`absolute inset-0 transition-all duration-500 ${
                    index === 0
                      ? "opacity-100 translate-y-0"
                      : "opacity-0 translate-y-4 pointer-events-none"
                  }`}
                >
                  <div class="text-center">
                    <span class="text-xs text-primary font-mono">
                      {value.number}
                    </span>
                    <h3 class="text-xl font-semibold text-foreground mt-2 mb-3">
                      {value.title}
                    </h3>
                    <p class="text-muted-foreground max-w-sm mx-auto">
                      {value.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Value indicators -->
          <div class="flex justify-center gap-2 mt-6">
            {
              values.map((_, index) => (
                <button
                  type="button"
                  data-value-dot={index}
                  class={`h-1.5 rounded-full transition-all duration-300 ${
                    index === 0
                      ? "w-6 bg-primary"
                      : "w-1.5 bg-border hover:bg-muted-foreground"
                  }`}
                  aria-label={`View value ${index + 1}`}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const valueSlides = document.querySelectorAll<HTMLElement>("[data-value]");
  const valueDots = document.querySelectorAll<HTMLElement>("[data-value-dot]");
  let activeValue = 0;
  let valueInterval: number;

  function goToValue(index: number) {
    valueSlides[activeValue].classList.add("opacity-0", "translate-y-4", "pointer-events-none");
    valueSlides[activeValue].classList.remove("opacity-100", "translate-y-0");
    valueDots[activeValue].classList.remove("w-6", "bg-primary");
    valueDots[activeValue].classList.add("w-1.5", "bg-border");

    activeValue = index;

    valueSlides[activeValue].classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
    valueSlides[activeValue].classList.add("opacity-100", "translate-y-0");
    valueDots[activeValue].classList.add("w-6", "bg-primary");
    valueDots[activeValue].classList.remove("w-1.5", "bg-border");
  }

  function startValueAutoPlay() {
    valueInterval = window.setInterval(() => {
      goToValue((activeValue + 1) % valueSlides.length);
    }, 4000);
  }

  valueDots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      clearInterval(valueInterval);
      goToValue(i);
      startValueAutoPlay();
    });
  });

  startValueAutoPlay();
</script>
